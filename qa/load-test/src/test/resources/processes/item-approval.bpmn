if (execution.getVariable("BASE_URL") == null) {
  execution.setVariable("BASE_URL", "http://item-mock:8080");
}

if (execution.getVariable("SERVICE_API_URL") == null) {
  execution.setVariable("SERVICE_API_URL", "http://service-mock:8080");
}

if (execution.getVariable("API_KEY") == null) {
  execution.setVariable("API_KEY", "test-api-key");
}

var Instant = Java.type("java.time.Instant");
execution.setVariable("START_TIME", Instant.now().toString());</bpmn:script>
