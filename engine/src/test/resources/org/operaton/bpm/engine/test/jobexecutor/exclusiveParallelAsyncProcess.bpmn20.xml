<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:operaton="http://operaton.org/schema/1.0/bpmn" targetNamespace="Examples">
  <process id="exclusiveParallelAsyncProcess" name="exclusiveParallelAsyncProcess" isExecutable="true">
    <startEvent id="theStart" name="Start"></startEvent>
    <parallelGateway id="fork"></parallelGateway>
    <serviceTask id="servicetask1" name="Service Task 1" operaton:expression="${true}" operaton:async="true"></serviceTask>
    <serviceTask id="servicetask2" name="Service Task 2" operaton:expression="${true}" operaton:async="true"></serviceTask>
    <endEvent id="endevent1" name="End 1"></endEvent>
    <endEvent id="endevent2" name="End 2"></endEvent>
    <sequenceFlow id="flow1" sourceRef="theStart" targetRef="fork"></sequenceFlow>
    <sequenceFlow id="flow2" sourceRef="fork" targetRef="servicetask1"></sequenceFlow>
    <sequenceFlow id="flow3" sourceRef="fork" targetRef="servicetask2"></sequenceFlow>
    <sequenceFlow id="flow4" sourceRef="servicetask1" targetRef="endevent1"></sequenceFlow>
    <sequenceFlow id="flow5" sourceRef="servicetask2" targetRef="endevent2"></sequenceFlow>
  </process>
</definitions>
