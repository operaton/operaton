# Build used when webapps-neo is embedded into the Operaton (Run) distribution.
# The SPA is served from the application root and talks to the backend on the
# same origin, so the backend url is empty (requests go to /engine-rest).
VITE_BACKEND=[{"name": "Operaton", "url": ""}]
# Authenticate against the backend through the Spring OAuth2 module (server-side
# session). No VITE_OAUTH_AUTHORITY is set, so the client-side PKCE flow stays
# disabled and the SPA delegates the handshake to the server.
VITE_AUTH_MODE=oauth
