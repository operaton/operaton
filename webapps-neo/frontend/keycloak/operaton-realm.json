{
  "realm": "operaton",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "roles": {
    "realm": [
      {
        "name": "operaton-admin",
        "description": "Operaton administrator role"
      },
      {
        "name": "operaton-user",
        "description": "Operaton standard user role"
      },
      {
        "name": "operaton-modeler",
        "description": "Operaton BPMN modeler role — allows creating and deploying diagrams"
      }
    ]
  },
  "groups": [
    {
      "name": "operaton-admin",
      "path": "/operaton-admin"
    },
    {
      "name": "operaton-user",
      "path": "/operaton-user"
    }
  ],
  "clients": [
    {
      "clientId": "operaton-web-apps",
      "name": "Operaton Web Apps",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://127.0.0.1:5173/*",
        "http://localhost:5173/*",
        "http://localhost:3000/*",
        "http://localhost/*",
        "http://localhost:1111/*"
      ],
      "webOrigins": [
        "http://127.0.0.1:5173",
        "http://localhost:5173",
        "http://localhost:3000",
        "http://localhost",
        "http://localhost:1111"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "operaton-identity-service",
      "name": "Operaton Identity Service",
      "description": "Service account client for the Operaton Keycloak Identity Provider Plugin",
      "enabled": true,
      "publicClient": false,
      "secret": "operaton-identity-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "demo",
      "email": "demo@operaton.org",
      "enabled": true,
      "firstName": "Demo",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "demo",
          "temporary": false
        }
      ],
      "realmRoles": [
        "operaton-admin",
        "operaton-user",
        "operaton-modeler"
      ],
      "groups": [
        "/operaton-admin"
      ]
    },
    {
      "username": "john",
      "email": "john@operaton.org",
      "enabled": true,
      "firstName": "John",
      "lastName": "Doe",
      "credentials": [
        {
          "type": "password",
          "value": "john",
          "temporary": false
        }
      ],
      "realmRoles": [
        "operaton-user"
      ],
      "groups": [
        "/operaton-user"
      ]
    },
    {
      "username": "service-account-operaton-identity-service",
      "enabled": true,
      "serviceAccountClientId": "operaton-identity-service",
      "realmRoles": [
        "default-roles-operaton"
      ],
      "clientRoles": {
        "realm-management": [
          "query-groups",
          "query-users",
          "view-users"
        ]
      }
    }
  ]
}
