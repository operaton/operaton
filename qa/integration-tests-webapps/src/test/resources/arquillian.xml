<?xml version="1.0" encoding="UTF-8"?>
<arquillian xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="http://jboss.org/schema/arquillian http://jboss.org/schema/arquillian/arquillian-1.0.xsd">

  <engine>
        <property name="deploymentExportPath">target/deployments</property>
  </engine>

  <container qualifier="wildfly">
    <configuration>
      <property name="jbossHome">${wildfly.runtime.location}</property>
      <property name="managementPort">39990</property>
      <property name="serverConfig">standalone.xml</property>
      <property name="javaVmArguments">-Xmx1024m</property>
      <!-- <property name="javaVmArguments">-Xmx1024m -Xrunjdwp:transport=dt_socket,address=8787,server=y,suspend=y</property> -->
      <property name="startupTimeoutInSeconds">300</property>
    </configuration>
  </container>

  <container qualifier="tomcat">
    <configuration>
      <property name="catalinaHome">${tomcat.runtime.location}</property>
      <property name="catalinaBase">${tomcat.runtime.location}</property>
      <property name="bindHttpPort">48080</property>
      <property name="user">arquillian</property>
      <property name="pass">arquillian</property>
      <property name="jmxPort">8089</property>
      <property name="javaVmArguments">-Xmx512m</property>
      <property name="startupTimeoutInSeconds">10</property>
      <!--       <property name="javaVmArguments">-Xmx512m -Xrunjdwp:transport=dt_socket,address=8787,server=y,suspend=y</property> -->
    </configuration>
  </container>


</arquillian>
