<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_InsuranceClaim"
                  targetNamespace="http://operaton.org/dev-fixtures">
  <bpmn:error id="Error_FraudSuspected" name="FraudSuspected" errorCode="FRAUD" />

  <bpmn:process id="insuranceClaim" name="Insurance Claim" isExecutable="true" camunda:historyTimeToLive="P30D">
    <bpmn:startEvent id="StartEvent_Filed" name="Claim filed">
      <bpmn:outgoing>Flow_StartToSubmit</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="UserTask_Submit" name="Submit claim form"
                   camunda:assignee="demo"
                   camunda:formKey="camunda-forms:deployment:insurance-submit.form">
      <bpmn:incoming>Flow_StartToSubmit</bpmn:incoming>
      <bpmn:outgoing>Flow_SubmitToRouting</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:businessRuleTask id="BusinessRuleTask_Routing" name="Determine routing"
                           camunda:decisionRef="claimRouting"
                           camunda:mapDecisionResult="singleEntry"
                           camunda:resultVariable="routing">
      <bpmn:incoming>Flow_SubmitToRouting</bpmn:incoming>
      <bpmn:outgoing>Flow_RoutingToInvestigation</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:subProcess id="SubProcess_Investigation" name="Investigation">
      <bpmn:incoming>Flow_RoutingToInvestigation</bpmn:incoming>
      <bpmn:outgoing>Flow_InvestigationToFanout</bpmn:outgoing>
      <bpmn:startEvent id="StartEvent_InvBegin">
        <bpmn:outgoing>Flow_InvStart</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:userTask id="UserTask_Assess" name="Assess claim" camunda:assignee="demo">
        <bpmn:incoming>Flow_InvStart</bpmn:incoming>
        <bpmn:outgoing>Flow_AssessToInvEnd</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:endEvent id="EndEvent_InvEnd">
        <bpmn:incoming>Flow_AssessToInvEnd</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_InvStart" sourceRef="StartEvent_InvBegin" targetRef="UserTask_Assess" />
      <bpmn:sequenceFlow id="Flow_AssessToInvEnd" sourceRef="UserTask_Assess" targetRef="EndEvent_InvEnd" />
    </bpmn:subProcess>

    <bpmn:boundaryEvent id="BoundaryEvent_Escalate" name="Escalate (24h)" attachedToRef="SubProcess_Investigation">
      <bpmn:outgoing>Flow_EscalateToCompensate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Esc">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT24H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:boundaryEvent id="BoundaryEvent_Fraud" name="Fraud!" attachedToRef="SubProcess_Investigation">
      <bpmn:outgoing>Flow_FraudToCompensate</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrDef_Fraud" errorRef="Error_FraudSuspected" />
    </bpmn:boundaryEvent>

    <bpmn:inclusiveGateway id="Gateway_Fanout" name="Parallel paths" default="Flow_FanoutDocs">
      <bpmn:incoming>Flow_InvestigationToFanout</bpmn:incoming>
      <bpmn:outgoing>Flow_FanoutDocs</bpmn:outgoing>
      <bpmn:outgoing>Flow_FanoutDamage</bpmn:outgoing>
    </bpmn:inclusiveGateway>

    <bpmn:serviceTask id="ServiceTask_Docs" name="Document review"
                      camunda:type="external" camunda:topic="document-review">
      <bpmn:incoming>Flow_FanoutDocs</bpmn:incoming>
      <bpmn:outgoing>Flow_DocsToJoin</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="ServiceTask_Damage" name="Compute damage"
                      camunda:type="external" camunda:topic="compute-damage">
      <bpmn:incoming>Flow_FanoutDamage</bpmn:incoming>
      <bpmn:outgoing>Flow_DamageToJoin</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:inclusiveGateway id="Gateway_Join">
      <bpmn:incoming>Flow_DocsToJoin</bpmn:incoming>
      <bpmn:incoming>Flow_DamageToJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_JoinToDecision</bpmn:outgoing>
    </bpmn:inclusiveGateway>

    <bpmn:userTask id="UserTask_Decision" name="Approve or deny" camunda:assignee="demo">
      <bpmn:incoming>Flow_JoinToDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_DecisionToEnd</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="EndEvent_Done" name="Resolved">
      <bpmn:incoming>Flow_DecisionToEnd</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:serviceTask id="ServiceTask_Compensate" name="Refund"
                      camunda:type="external" camunda:topic="compensate-payment"
                      isForCompensation="true">
    </bpmn:serviceTask>

    <bpmn:intermediateThrowEvent id="ThrowEvent_Compensate" name="Compensate">
      <bpmn:incoming>Flow_EscalateToCompensate</bpmn:incoming>
      <bpmn:incoming>Flow_FraudToCompensate</bpmn:incoming>
      <bpmn:outgoing>Flow_CompensateToCancel</bpmn:outgoing>
      <bpmn:compensateEventDefinition id="CompDef_Throw" />
    </bpmn:intermediateThrowEvent>

    <bpmn:endEvent id="EndEvent_Cancelled" name="Cancelled">
      <bpmn:incoming>Flow_CompensateToCancel</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartToSubmit" sourceRef="StartEvent_Filed" targetRef="UserTask_Submit" />
    <bpmn:sequenceFlow id="Flow_SubmitToRouting" sourceRef="UserTask_Submit" targetRef="BusinessRuleTask_Routing" />
    <bpmn:sequenceFlow id="Flow_RoutingToInvestigation" sourceRef="BusinessRuleTask_Routing" targetRef="SubProcess_Investigation" />
    <bpmn:sequenceFlow id="Flow_InvestigationToFanout" sourceRef="SubProcess_Investigation" targetRef="Gateway_Fanout" />
    <bpmn:sequenceFlow id="Flow_FanoutDocs" sourceRef="Gateway_Fanout" targetRef="ServiceTask_Docs" />
    <bpmn:sequenceFlow id="Flow_FanoutDamage" sourceRef="Gateway_Fanout" targetRef="ServiceTask_Damage">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${routing != "fast-track"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_DocsToJoin" sourceRef="ServiceTask_Docs" targetRef="Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_DamageToJoin" sourceRef="ServiceTask_Damage" targetRef="Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_JoinToDecision" sourceRef="Gateway_Join" targetRef="UserTask_Decision" />
    <bpmn:sequenceFlow id="Flow_DecisionToEnd" sourceRef="UserTask_Decision" targetRef="EndEvent_Done" />
    <bpmn:sequenceFlow id="Flow_EscalateToCompensate" sourceRef="BoundaryEvent_Escalate" targetRef="ThrowEvent_Compensate" />
    <bpmn:sequenceFlow id="Flow_FraudToCompensate" sourceRef="BoundaryEvent_Fraud" targetRef="ThrowEvent_Compensate" />
    <bpmn:sequenceFlow id="Flow_CompensateToCancel" sourceRef="ThrowEvent_Compensate" targetRef="EndEvent_Cancelled" />

    <bpmn:association id="Association_CompensateLink" associationDirection="One"
                      sourceRef="ServiceTask_Compensate" targetRef="ServiceTask_Compensate" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_InsuranceClaim">
    <bpmndi:BPMNPlane id="BPMNPlane_InsuranceClaim" bpmnElement="insuranceClaim">
      <bpmndi:BPMNShape id="StartEvent_Filed_di" bpmnElement="StartEvent_Filed">
        <dc:Bounds x="120" y="180" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_Submit_di" bpmnElement="UserTask_Submit">
        <dc:Bounds x="220" y="158" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BusinessRuleTask_Routing_di" bpmnElement="BusinessRuleTask_Routing">
        <dc:Bounds x="360" y="158" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SubProcess_Investigation_di" bpmnElement="SubProcess_Investigation" isExpanded="false">
        <dc:Bounds x="500" y="158" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BoundaryEvent_Escalate_di" bpmnElement="BoundaryEvent_Escalate">
        <dc:Bounds x="520" y="220" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BoundaryEvent_Fraud_di" bpmnElement="BoundaryEvent_Fraud">
        <dc:Bounds x="570" y="220" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Fanout_di" bpmnElement="Gateway_Fanout" isMarkerVisible="true">
        <dc:Bounds x="660" y="173" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_Docs_di" bpmnElement="ServiceTask_Docs">
        <dc:Bounds x="760" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_Damage_di" bpmnElement="ServiceTask_Damage">
        <dc:Bounds x="760" y="240" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Join_di" bpmnElement="Gateway_Join" isMarkerVisible="true">
        <dc:Bounds x="900" y="173" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_Decision_di" bpmnElement="UserTask_Decision">
        <dc:Bounds x="1000" y="158" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Done_di" bpmnElement="EndEvent_Done">
        <dc:Bounds x="1140" y="180" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_Compensate_di" bpmnElement="ServiceTask_Compensate">
        <dc:Bounds x="500" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ThrowEvent_Compensate_di" bpmnElement="ThrowEvent_Compensate">
        <dc:Bounds x="700" y="340" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Cancelled_di" bpmnElement="EndEvent_Cancelled">
        <dc:Bounds x="800" y="340" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_StartToSubmit_di" bpmnElement="Flow_StartToSubmit">
        <di:waypoint x="156" y="198" /><di:waypoint x="220" y="198" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SubmitToRouting_di" bpmnElement="Flow_SubmitToRouting">
        <di:waypoint x="320" y="198" /><di:waypoint x="360" y="198" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_RoutingToInvestigation_di" bpmnElement="Flow_RoutingToInvestigation">
        <di:waypoint x="460" y="198" /><di:waypoint x="500" y="198" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_InvestigationToFanout_di" bpmnElement="Flow_InvestigationToFanout">
        <di:waypoint x="620" y="198" /><di:waypoint x="660" y="198" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_FanoutDocs_di" bpmnElement="Flow_FanoutDocs">
        <di:waypoint x="685" y="173" /><di:waypoint x="685" y="120" /><di:waypoint x="760" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_FanoutDamage_di" bpmnElement="Flow_FanoutDamage">
        <di:waypoint x="685" y="223" /><di:waypoint x="685" y="280" /><di:waypoint x="760" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_DocsToJoin_di" bpmnElement="Flow_DocsToJoin">
        <di:waypoint x="860" y="120" /><di:waypoint x="925" y="120" /><di:waypoint x="925" y="173" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_DamageToJoin_di" bpmnElement="Flow_DamageToJoin">
        <di:waypoint x="860" y="280" /><di:waypoint x="925" y="280" /><di:waypoint x="925" y="223" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_JoinToDecision_di" bpmnElement="Flow_JoinToDecision">
        <di:waypoint x="950" y="198" /><di:waypoint x="1000" y="198" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_DecisionToEnd_di" bpmnElement="Flow_DecisionToEnd">
        <di:waypoint x="1100" y="198" /><di:waypoint x="1140" y="198" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EscalateToCompensate_di" bpmnElement="Flow_EscalateToCompensate">
        <di:waypoint x="538" y="256" /><di:waypoint x="538" y="358" /><di:waypoint x="700" y="358" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_FraudToCompensate_di" bpmnElement="Flow_FraudToCompensate">
        <di:waypoint x="588" y="256" /><di:waypoint x="588" y="358" /><di:waypoint x="700" y="358" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_CompensateToCancel_di" bpmnElement="Flow_CompensateToCancel">
        <di:waypoint x="736" y="358" /><di:waypoint x="800" y="358" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
